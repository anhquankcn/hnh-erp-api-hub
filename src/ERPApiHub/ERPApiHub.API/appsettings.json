{
  "ConnectionStrings": {
    "Default": "Host=localhost;Port=5452;Database=erphub_api_db;Username=erphub;Password=<set-via-env-or-secrets>"
  },
  "Redis": {
    "ConnectionString": "redis:6379,abortConnect=false",
    "Password": "",
    "InstanceName": "erphub:",
    "DefaultTtlMinutes": 5,
    "LookupTtlMinutes": 15
  },
  "Cache": {
    "Enabled": true,
    "DefaultTtl": "00:05:00",
    "L1Ttl": "00:01:00",
    "RedisKeyPrefix": "erphub:",
    "TagKeyPrefix": "cache:tag:",
    "KeyIndexSet": "cache:keys"
  },
  "Jobs": {
    "Enabled": true,
    "DashboardEnabled": true,
    "DashboardPath": "/hangfire",
    "RedisPrefix": "erphub:hangfire:",
    "CacheWarmingCron": "*/15 * * * *",
    "CacheEvictionCron": "*/30 * * * *",
    "HealthAggregationCron": "*/5 * * * *",
    "TenantIds": [],
    "FrequentlyAccessedDoctypes": [
      "Customer",
      "Item",
      "Sales Order"
    ],
    "WarmPageSize": 50,
    "WarmPageCount": 1,
    "HealthAggregationCacheTtlMinutes": 10
  },
  "RabbitMQ": {
    "Host": "localhost",
    "Port": 5672,
    "Username": "guest",
    "Password": "<set-via-env-or-secrets>",
    "VirtualHost": "/",
    "ExchangeName": "1stopshop_event_bus",
    "IngestionQueue": "erphub.ingestion",
    "IngestionBindingKey": "erphub.ingestion.#",
    "IngestionDeadLetterQueue": "erphub.dlq.ingestion"
  },
  "Keycloak": {
    "Authority": "http://localhost:8080/realms/HNHTravel-SGN",
    "Audience": "erp-api-hub",
    "RequireHttpsMetadata": false
  },
  "RateLimit": {
    "Enabled": true,
    "WindowSeconds": 60,
    "DefaultTier": "TIER_3",
    "Tiers": {
      "TIER_1": { "RequestsPerMinute": 10000, "BurstMultiplier": 2 },
      "TIER_2": { "RequestsPerMinute": 1000, "BurstMultiplier": 2 },
      "TIER_3": { "RequestsPerMinute": 100, "BurstMultiplier": 2 }
    },
    "EndpointReduction": {
      "Ingestion": 0.50,
      "Query": 1.00,
      "WebhookManagement": 0.10,
      "Admin": 0.05,
      "Other": 1.00
    }
  },
  "ErpNextEvents": {
    "SharedSecret": "<set-via-env-or-secrets>",
    "MaxClockSkewSeconds": 300,
    "Enabled": true,
    "AllowedIpRanges": ["127.0.0.1/32", "::1/128"]
  },
  "OpenTelemetry": {
    "Enabled": false,
    "OtlpEndpoint": "",
    "ServiceName": "ERPApiHub",
    "ServiceVersion": "1.0.0"
  },
  "LinkFieldValidation": {
    "Enabled": true,
    "TimeoutSeconds": 5,
    "FailOnInvalid": false,
    "ExcludedDoctypes": ["User", "Role Profile"]
  }
}
