{
  "ConnectionStrings": {
    "Default": "Host=localhost;Port=5452;Database=erphub_api_db;Username=erphub;Password=erphub"
  },
  "RabbitMQ": {
    "Host": "localhost",
    "Port": 5672,
    "Username": "guest",
    "Password": "guest",
    "VirtualHost": "/",
    "ExchangeName": "1stopshop_event_bus",
    "IngestionQueue": "erphub.ingestion",
    "IngestionBindingKey": "erphub.ingestion.#",
    "IngestionDeadLetterQueue": "erphub.dlq.ingestion"
  },
  "TenantHealthCheck": {
    "Enabled": true,
    "IntervalMinutes": 5,
    "TimeoutSeconds": 10,
    "DegradedThresholdMs": 2000,
    "AlertOn": [
      "unhealthy",
      "degraded"
    ]
  },
  "Polling": {
    "Enabled": true,
    "SchedulerInterval": "00:00:10",
    "CriticalInterval": "00:00:30",
    "StandardInterval": "00:05:00",
    "CursorTtl": "1.00:00:00",
    "InitialCursorLookback": "01:00:00",
    "Backoff": {
      "RateLimitDelay": "00:01:00"
    },
    "Doctypes": [
      {
        "Name": "Sales Invoice",
        "Priority": "critical",
        "LastCursorField": "modified"
      },
      {
        "Name": "Customer",
        "Priority": "standard",
        "LastCursorField": "modified"
      },
      {
        "Name": "Item",
        "Priority": "standard",
        "LastCursorField": "modified"
      },
      {
        "Name": "Sales Order",
        "Priority": "critical",
        "LastCursorField": "modified"
      },
      {
        "Name": "Purchase Order",
        "Priority": "standard",
        "LastCursorField": "modified"
      }
    ]
  }
}
