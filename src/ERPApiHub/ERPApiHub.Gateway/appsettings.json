{
  "Keycloak": {
    "Authority": "http://localhost:8080/realms/HNHTravel-SGN",
    "Audience": "erp-api-hub",
    "RequireHttpsMetadata": false
  },
  "ReverseProxy": {
    "Routes": {
      "api": {
        "ClusterId": "erp-api-hub",
        "Match": {
          "Path": "/api/{**catch-all}"
        },
        "Transforms": [
          {
            "PathRemovePrefix": "/api"
          }
        ]
      }
    },
    "Clusters": {
      "erp-api-hub": {
        "Destinations": {
          "api": {
            "Address": "http://erp-api-hub:8008/"
          }
        }
      }
    }
  }
}
