{
  "Keycloak": {
    "Authority": "http://localhost:8080/realms/HNHTravel-SGN",
    "Audience": "erp-api-hub",
    "RequireHttpsMetadata": false
  },
  "ReverseProxy": {
    "Routes": {
      "erp-api-hub": {
        "ClusterId": "erp-api-hub",
        "AuthorizationPolicy": "InternalGateway",
        "Match": {
          "Path": "/api/erp/{**catch-all}"
        },
        "Transforms": [
          {
            "PathRemovePrefix": "/api/erp"
          }
        ]
      },
      "erpnext": {
        "ClusterId": "erpnext",
        "AuthorizationPolicy": "InternalGateway",
        "Match": {
          "Path": "/api/method/{**catch-all}"
        },
        "Transforms": [
          {
            "PathRemovePrefix": "/api/method"
          }
        ]
      }
    },
    "Clusters": {
      "erp-api-hub": {
        "Destinations": {
          "primary": {
            "Address": "http://erp-api-hub:8008/"
          }
        }
      },
      "erpnext": {
        "Destinations": {
          "primary": {
            "Address": "http://erpnext:8080/"
          }
        }
      }
    },
    "_comment": "Routes for erp-api-hub and erpnext. Add routes for core-service, crm-service, ticketing-service, payment-service, accounting-service when ready."
  }
}
